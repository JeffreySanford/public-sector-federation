{
  "name": "starlight",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/starlight/src",
  "projectType": "application",
  "implicitDependencies": ["tokens"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir packages/tokens build && pnpm --dir apps/starlight dev"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/starlight"],
      "options": {
        "command": "pnpm --dir packages/tokens build && pnpm --dir apps/starlight build"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir apps/starlight preview"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir packages/tokens build && pnpm --dir apps/starlight check"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir packages/tokens build && pnpm --dir apps/starlight check"
      }
    },
    "quality-gate": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": [
        "{workspaceRoot}/playwright-report/starlight",
        "{workspaceRoot}/test-results/starlight",
        "{workspaceRoot}/artifacts/lighthouse/starlight"
      ],
      "options": {
        "commands": [
          "node scripts/validate-starlight-quality.mjs",
          "pnpm exec playwright test --config apps/starlight/playwright.config.ts",
          "pnpm exec lhci autorun --config apps/starlight/lighthouserc.cjs"
        ],
        "parallel": false
      }
    }
  },
  "tags": ["scope:documentation", "type:application"]
}
