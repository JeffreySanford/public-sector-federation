# Environment variable sample
#
# Copy this file to `.env` for local development:
#
#   cp .env.sample .env
#
# Do not commit `.env`. It is gitignored because it may contain secrets.
# Leave values blank here unless they are safe public defaults.

# Chromatic
#
# Required for:
#   pnpm chromatic
#
# How to get it:
# 1. Open the Chromatic project for this repository.
# 2. Go to Manage > Configure > Project Token.
# 3. Copy the project token into your local `.env` file only.
# 4. In CI, store it as a secret named CHROMATIC_PROJECT_TOKEN.
CHROMATIC_PROJECT_TOKEN=

# Zeroheight publishing
#
# Required only when publishing an exported Zeroheight package.
# Keep access tokens in `.env` or the CI secret store only.
ZEROHEIGHT_PUBLISH_ENDPOINT=
ZEROHEIGHT_CLIENT_ID=
ZEROHEIGHT_ACCESS_TOKEN=
ZEROHEIGHT_DRY_RUN=true

# Optional local service URLs
#
# These have safe defaults in scripts, but can be overridden locally.
AGILE_API_URL=
PERFORMANCE_API_URL=
SCREENSHOT_BASE_URL=
A11Y_BASE_URL=

# Optional local database
#
# The app has a local development fallback. Override only when using a
# different database instance.
DATABASE_URL=

# Optional local runtime settings
PORT=
CORS_ORIGIN=
STORYBOOK_E2E_PORT=
SCREENSHOT_DIR=

# Optional reporting and automation
#
# Use only in local `.env` or CI secrets.
SLACK_WEBHOOK_URL=
GIT_COMMIT_HASH=
GIT_BRANCH=
AUTO_COMMIT=
PLATFORM_FORCE_REBUILD=
