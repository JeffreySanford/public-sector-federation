{
  "name": "ui-patterns",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ui-patterns/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir packages/ui-patterns build"
      }
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "buildTarget": "qa-remote:build",
        "tsConfig": "packages/ui-patterns/tsconfig.spec.json",
        "runner": "vitest"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir packages/ui-patterns typecheck"
      }
    }
  },
  "tags": ["scope:design-system", "type:patterns"]
}
