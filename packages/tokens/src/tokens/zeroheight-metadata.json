{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Documentation metadata applied to generated Zeroheight token exports.",
  "groups": {
    "surface": {
      "match": ["surface", "content-background", "content-border"],
      "tier": "semantic",
      "category": "Foundations / Surface",
      "usage": "Use for page, card, border, and container surfaces."
    },
    "text": {
      "match": ["text"],
      "tier": "semantic",
      "category": "Foundations / Text",
      "usage": "Use for primary and supporting text across shell and remotes."
    },
    "action": {
      "match": ["primary", "action", "button"],
      "tier": "component",
      "category": "Actions",
      "usage": "Use for action hierarchy, PrimeNG buttons, and interactive emphasis."
    },
    "feedback": {
      "match": ["danger", "success", "warn", "toast"],
      "tier": "component",
      "category": "Feedback",
      "usage": "Use for semantic statuses, toast messages, and alert-like feedback."
    },
    "data": {
      "match": ["datatable", "paginator"],
      "tier": "component",
      "category": "Data Display",
      "usage": "Use for PrimeNG table, sorting, filtering, and pagination surfaces."
    },
    "overlay": {
      "match": ["dialog", "menu"],
      "tier": "component",
      "category": "Overlays",
      "usage": "Use for dialog, menu, and overlay surfaces that must work in federation."
    },
    "foundation": {
      "match": ["radius", "space", "font", "focus-ring"],
      "tier": "foundation",
      "category": "Foundations",
      "usage": "Use for shape, spacing, typography, and visible focus behavior."
    }
  },
  "tokenDescriptions": {
    "--ps-surface-background": "Application background color.",
    "--ps-surface-card": "Card and panel background color.",
    "--ps-surface-border": "Default border color for surfaces.",
    "--ps-text-primary": "Primary readable text color.",
    "--ps-text-secondary": "Muted supporting text color.",
    "--ps-action-text": "Accessible action foreground for outlined and text actions.",
    "--ps-button-background": "Filled action background color.",
    "--ps-button-text": "Filled action foreground color.",
    "--p-button-gap": "PrimeNG button icon and label gap.",
    "--p-card-background": "PrimeNG card background mapping.",
    "--p-datatable-header-cell-background": "PrimeNG table header background mapping.",
    "--p-paginator-nav-button-selected-background": "Selected paginator page background.",
    "--p-dialog-background": "PrimeNG dialog surface mapping.",
    "--p-toast-message-success-background": "Success toast message surface."
  },
  "primeNgFamilies": {
    "--p-button": "Button",
    "--p-card": "Card",
    "--p-datatable": "Table",
    "--p-paginator": "Paginator",
    "--p-dialog": "Dialog",
    "--p-toast": "Toast",
    "--p-menu": "Menu"
  }
}
