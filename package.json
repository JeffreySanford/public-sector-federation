{
  "name": "public-sector-federation",
  "version": "1.0.0",
  "private": true,
  "description": "Public sector Angular module federation reference using web components, PrimeNG wrappers, design tokens, Storybook, and automated quality evidence.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22 <27"
  },
  "scripts": {
    "nx": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js",
    "build": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run-many -t build",
    "typecheck": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run-many -t typecheck",
    "lint": "node scripts/lint-workspace.mjs",
    "lint:links": "node scripts/check-links.mjs",
    "lint:public": "node scripts/check-public-references.mjs",
    "lint:wrappers": "node scripts/check-wrapper-contracts.mjs && node scripts/build-component-manifest.mjs --check",
    "test": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run-many -t test",
    "e2e": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run-many -t e2e",
    "graph": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js graph",
    "build:tokens": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run tokens:build",
    "manifest:build": "node scripts/build-component-manifest.mjs",
    "manifest:check": "node scripts/build-component-manifest.mjs --check",
    "guard:scss": "node scripts/guard-scss.mjs",
    "start:frontend": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run-many --target=serve --projects=services-remote,reporting-remote,admin-remote,qa-remote,shell --parallel=5 --outputStyle=stream",
    "start:backend": "node scripts/ensure-platform.mjs",
    "start:backend:rebuild": "node scripts/ensure-platform.mjs --rebuild",
    "start:all": "pnpm start:backend && pnpm start:frontend",
    "start:all:rebuild": "pnpm start:backend:rebuild && pnpm start:frontend",
    "check:dev-ports": "node scripts/check-dev-ports.mjs",
    "db:validate": "pnpm prisma validate --schema apps/agile-api/prisma/schema.prisma",
    "verify:smoke": "pnpm check:dev-ports && pnpm test:a11y",
    "verify:fed": "pnpm verify:smoke",
    "verify:release": "pnpm lint && pnpm lint:links && pnpm lint:public && pnpm typecheck && pnpm test && pnpm manifest:check && pnpm build && pnpm test:e2e",
    "docker:up": "docker compose up -d --build postgres agile-api",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f postgres agile-api",
    "api:prisma:generate": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run agile-api:prisma:generate",
    "api:migrate": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run agile-api:prisma:deploy",
    "api:seed": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run agile-api:seed",
    "serve:api": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run agile-api:serve",
    "check:platform": "pnpm start:backend && pnpm check:dev-ports",
    "start:platform": "pnpm start:all",
    "agile:report": "node scripts/export-agile-report.mjs",
    "perf:record": "node scripts/record-performance.mjs",
    "perf:export-seed": "node scripts/export-performance-seed.mjs",
    "screenshots:progress": "node scripts/capture-progress-screenshots.mjs",
    "zip:screenshots": "node scripts/zip-latest-screenshots.mjs",
    "zeroheight:export": "node scripts/export-zeroheight-package.mjs",
    "zeroheight:publish": "node scripts/publish-zeroheight-package.mjs",
    "report:all": "pnpm verify:smoke && pnpm screenshots:progress && pnpm agile:report && pnpm zeroheight:export && pnpm zip:screenshots",
    "report:publish": "pnpm report:all && pnpm zeroheight:publish",
    "serve:shell": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js serve shell",
    "serve:services": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js serve services-remote",
    "serve:reporting": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js serve reporting-remote",
    "serve:admin": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js serve admin-remote",
    "serve:qa": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js serve qa-remote",
    "serve:playground": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js serve playground",
    "storybook:qa": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run qa-remote:storybook",
    "build-storybook:qa": "node ./node_modules/.pnpm/nx@23.0.1/node_modules/nx/dist/bin/nx.js run qa-remote:build-storybook",
    "test:a11y": "node scripts/a11y-check.mjs",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "test:code-examples": "playwright test CODE_EXAMPLES.test.ts",
    "test:api": "pnpm nx run agile-api:test",
    "test:storybook:qa": "playwright test apps/qa-remote/e2e/storybook-stories.spec.ts",
    "test:storybook:qa:chromium": "playwright test apps/qa-remote/e2e/storybook-stories.spec.ts --project=chromium --workers=1",
    "test:storybook:up-button": "playwright test apps/qa-remote/e2e/up-button-candidate.storybook.spec.ts",
    "test:storybook:up-button:chromium": "playwright test apps/qa-remote/e2e/up-button-candidate.storybook.spec.ts --project=chromium --workers=1",
    "test:storybook:registry": "playwright test apps/qa-remote/e2e/component-registry.storybook.spec.ts",
    "test:storybook:registry:chromium": "playwright test apps/qa-remote/e2e/component-registry.storybook.spec.ts --project=chromium --workers=1",
    "chromatic": "node scripts/chromatic-up-button.mjs"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.0.0",
    "@angular-devkit/schematics": "^21.0.0",
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@axe-core/playwright": "latest",
    "@nx/angular": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/module-federation": "23.0.1",
    "@nx/storybook": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.61.1",
    "@schematics/angular": "^21.0.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/angular": "^10.4.6",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "chromatic": "^18.0.1",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli2": "^0.23.0",
    "nx": "23.0.1",
    "playwright": "latest",
    "prisma": "^7.8.0",
    "storybook": "^10.4.6",
    "typescript": "~5.9.0"
  },
  "dependencies": {
    "@angular-architects/module-federation": "21.2.2",
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/elements": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@module-federation/enhanced": "2.7.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@primeuix/styled": "0.7.4",
    "@primeuix/themes": "^2.0.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "chart.js": "latest",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.22.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  }
}
